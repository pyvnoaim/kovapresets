{
  "name": "kovapreset",
  "version": "1.0.4",
  "private": true,
  "description": "Switch KovaaK's theme / crosshair / sound presets, live while the game is open.",
  "author": "pyvnoaim",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pyvnoaim/kovapresets.git"
  },
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "core:test": "node src/core/selftest.js",
    "dist": "electron-builder",
    "release": "electron-builder --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "app.kova.presets",
    "productName": "KovaPresets",
    "files": [
      "src/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "pyvnoaim",
        "repo": "kovapresets",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/app.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "shortcutName": "KovaPresets",
      "uninstallDisplayName": "KovaPresets",
      "deleteAppDataOnUninstall": false
    }
  }
}
